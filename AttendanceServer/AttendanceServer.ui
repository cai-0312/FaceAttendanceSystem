  <property name="styleSheet">
   <string notr="true">/* 主窗口与全局背景色 */
QWidget#AttendanceServerClass {
    background-color: #F2F3F5;
}
/* 7. 退出登录按钮专属样式 */
QPushButton#btn_LogoutServer {
    background-color: #FFFFFF;
    color: #4E5969;
    border: 1px solid #E5E6EB;
}
QPushButton#btn_LogoutServer:hover {
    color: #F53F3F;
    border-color: #F53F3F;
    background-color: #FEF0F0;
}
QPushButton#btn_LogoutServer:pressed {
    background-color: #FFECE8;
}
/*  全局普通按钮美化 (圆角、边框、悬浮动画) */
QPushButton {
    background-color: #FFFFFF;
    border: 1px solid #E5E6EB;
    color: #4E5969;
    border-radius: 6px;
    padding: 6px 16px;
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 13px;
    font-weight: bold;
    outline: none;
}
QPushButton:hover {
    color: #165DFF;
    border-color: #165DFF;
    background-color: #F8FBFF;
}
QPushButton:pressed {
    background-color: #E8F3FF;
}

/*  针对启动/确认等主要按钮 (蓝色系) */
QPushButton#btn_StartServer, QPushButton#btn_RefreshData, QPushButton#btn_ExportGlobal {
    background-color: #165DFF;
    color: white;
    border: none;
}
QPushButton#btn_StartServer:hover, QPushButton#btn_RefreshData:hover, QPushButton#btn_ExportGlobal:hover {
    background-color: #4080FF;
}
QPushButton#btn_StartServer:pressed, QPushButton#btn_RefreshData:pressed, QPushButton#btn_ExportGlobal:pressed {
    background-color: #0E42D2;
}

/*  针对停止/危险操作按钮 (红色系) */
QPushButton#btn_StopServer {
    background-color: #F53F3F;
    color: white;
    border: none;
}
QPushButton#btn_StopServer:hover {
    background-color: #F76560;
}
QPushButton#btn_StopServer:pressed {
    background-color: #CB272D;
}

/* 顺手美化全局输入框 */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #E5E6EB;
    border-radius: 6px;
    padding: 6px 10px;
    color: #1D2129;
}
QLineEdit:focus {
    border: 1px solid #165DFF;
}

/* 6. 顺手美化数据表格 (考勤流水账等) */
QTableView, QTableWidget {
    background-color: #FFFFFF;
    border: 1px solid #E5E6EB;
    border-radius: 8px;
    gridline-color: #F2F3F5;
    selection-background-color: #E8F3FF;
    selection-color: #165DFF;
}
QHeaderView::section {
    background-color: #F7F8FA;
    color: #4E5969;
    font-weight: bold;
    border: none;
    border-right: 1px solid #E5E6EB;
    border-bottom: 1px solid #E5E6EB;
    padding: 6px;
}</string>
