      <item>
       <widget class="QFrame" name="frame_RightForm">
        <property name="styleSheet">
         <string notr="true">
										/* 统一下拉框与输入框外观 */
										QLineEdit, QComboBox {
										border: 1px solid #DCDFE6;
										border-radius: 6px;
										padding: 6px 12px;
										background: white;
										color: #303133;
										font-size: 14px;
										min-height: 30px;
										}
										QLineEdit:hover, QComboBox:hover { border-color: #C0C4CC; }
										QLineEdit:focus, QComboBox:focus { border-color: #409EFF; }
										QComboBox::drop-down { border: none; width: 30px; }
										QComboBox::down-arrow { image: none; border-left: 5px solid transparent; border-right: 5px solid transparent; border-top: 6px solid #909399; margin-top: 2px; }

										/* 统一下拉列表的高颜值面板 */
										QComboBox QAbstractItemView {
										outline: none;
										border: 1px solid #E5E6EB;
										border-radius: 6px;
										background: white;
										padding: 4px;
										}
										QComboBox QAbstractItemView::item {
										min-height: 36px;
										color: #606266;
										padding-left: 8px;
										border-radius: 4px;
										margin: 2px;
										}
										QComboBox QAbstractItemView::item:hover { background-color: #F5F7FA; color: #409EFF; }
										QComboBox QAbstractItemView::item:selected { background-color: #ECF5FF; color: #409EFF; font-weight: bold; }

										/* 登录按钮 */
										QPushButton#btn_Login {
										background-color: #409EFF; color: white; border-radius: 6px; padding: 8px 20px; font-weight: bold; font-size: 15px; border: none; margin-top: 10px;
										}
										QPushButton#btn_Login:hover { background-color: #66B1FF; }
										QPushButton#btn_Login:pressed { background-color: #3A8EE6; }

										/* 注册确认按钮 */
										QPushButton#btn_ConfirmRegister {
										background-color: #67C23A; color: white; border-radius: 6px; padding: 8px 20px; font-weight: bold; border: none; margin-top: 10px;
										}
										QPushButton#btn_ConfirmRegister:hover { background-color: #85CE61; }

										/* 超链接文本按钮 */
										QPushButton#btn_GoRegister {
										color: #409EFF; border: none; background: transparent; text-decoration: underline; margin-top: 5px; font-size: 13px;
										}
										QPushButton#btn_GoRegister:hover { color: #66B1FF; }

										QPushButton#btn_BackLogin {
										color: #909399; border: none; background: transparent; text-decoration: underline; margin-top: 5px; font-size: 13px;
										}
										QPushButton#btn_BackLogin:hover { color: #606266; }

										/* 左侧文字标签对齐与美化 */
										QLabel { color: #606266; font-weight: bold; }
									</string>
        </property>
