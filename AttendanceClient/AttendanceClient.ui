        <property name="styleSheet">
         <string notr="true">
										/* 🚀 核心魔法：在这里加载图案背景，并保持左侧圆角 */
										QFrame#frame_LeftBrand {
										/* 如果找不到图片，会退化显示这个科技蓝渐变色保底 */
										background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #1890FF, stop:1 #33A3FF);

										/* 读取外部图片并拉伸填满。请将图片命名为 login_bg.jpg 放在项目目录下 */
										border-image: url(login_bg.jpg) 0 0 0 0 stretch stretch;

										border-top-left-radius: 12px;
										border-bottom-left-radius: 12px;
										}
